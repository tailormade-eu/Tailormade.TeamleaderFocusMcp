{
  "name": "@tailormade/teamleader-focus-mcp",
  "version": "1.3.0",
  "description": "MCP server for Teamleader Focus CRM - Extended with Time Tracking and Projects v2. Based on globodai-mcp-teamleader with additions from Tailormade CSV Importer implementation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "teamleader-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "teamleader",
    "teamleader-focus",
    "crm",
    "model-context-protocol",
    "ai",
    "claude",
    "time-tracking",
    "projects",
    "tailormade"
  ],
  "author": "Tailormade (based on Globodai MCP)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tailormade-eu/teamleader-focus-mcp.git"
  },
  "homepage": "https://github.com/tailormade-eu/teamleader-focus-mcp#readme",
  "bugs": {
    "url": "https://github.com/tailormade-eu/teamleader-focus-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
