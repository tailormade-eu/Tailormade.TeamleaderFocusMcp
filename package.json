{
  "name": "@tailormade/teamleader-focus-mcp",
  "version": "3.5.1",
  "description": "MCP server for Teamleader Focus CRM API — 112 tools covering contacts, companies, deals, tickets, invoices, subscriptions, meetings, projects, time tracking, files, notes, and smart cache-first task resolution.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "teamleader-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "check-coverage": "npx tsx tools/check-coverage.ts",
    "test": "vitest run",
    "scrape-api": "tsx scripts/scrape-tl-api.ts",
    "scrape-api:discover": "tsx scripts/scrape-tl-api.ts --discover-only",
    "scrape-api:diff": "tsx scripts/scrape-tl-api.ts --diff"
  },
  "keywords": [
    "mcp",
    "teamleader",
    "teamleader-focus",
    "crm",
    "model-context-protocol",
    "ai",
    "claude",
    "time-tracking",
    "projects",
    "tailormade"
  ],
  "author": "Tailormade",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tailormade-eu/Tailormade.TeamleaderFocusMcp.git"
  },
  "homepage": "https://github.com/tailormade-eu/Tailormade.TeamleaderFocusMcp#readme",
  "bugs": {
    "url": "https://github.com/tailormade-eu/Tailormade.TeamleaderFocusMcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "turndown": "^7.2.4",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
